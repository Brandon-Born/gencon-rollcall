rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function authorized() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/authorizedUsers/$(request.auth.uid));
    }

    match /maps/current/{fileName} {
      allow read: if authorized();
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
