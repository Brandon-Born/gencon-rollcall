rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authorized() {
      return signedIn()
        && exists(/databases/$(database)/documents/authorizedUsers/$(request.auth.uid));
    }

    function activeRallyPoint(rallyPointId) {
      return exists(/databases/$(database)/documents/rallyPoints/$(rallyPointId))
        && get(/databases/$(database)/documents/rallyPoints/$(rallyPointId)).data.status == 'active'
        && (
          get(/databases/$(database)/documents/rallyPoints/$(rallyPointId)).data.expiresAt == null
          || get(/databases/$(database)/documents/rallyPoints/$(rallyPointId)).data.expiresAt > request.time
        );
    }

    function validExpiration() {
      return resource.data.status == 'active'
        && resource.data.createdByMemberId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'expiresAt'])
        && request.resource.data.status == 'expired'
        && request.resource.data.expiresAt is timestamp;
    }

    function validMapId(mapId) {
      return mapId in [
        'exhibit-hall',
        'basement',
        'level-1',
        'level-2',
        'level-3',
        'level-4',
        'local-dev',
        'legacy'
      ];
    }

    function validMapPercent(value) {
      return value is number && value >= 0 && value <= 100;
    }

    function validMemberLocation(member) {
      return member.locationVisible is bool
        && (
          (
            member.locationVisible == true
            && validMapId(member.mapId)
            && validMapPercent(member.mapXPercent)
            && validMapPercent(member.mapYPercent)
          )
          || (
            member.locationVisible == false
            && member.mapId == null
            && member.mapXPercent == null
            && member.mapYPercent == null
          )
        );
    }

    function validMemberUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'mapId', 'mapXPercent', 'mapYPercent', 'locationVisible'
        ])
        || validMemberLocation(request.resource.data);
    }

    function validRallyPointCreate(rally) {
      return rally.keys().hasOnly([
          'title', 'note', 'mapId', 'mapXPercent', 'mapYPercent', 'scheduledTime',
          'createdByMemberId', 'createdByName', 'status', 'expiresAt'
        ])
        && rally.createdByMemberId == request.auth.uid
        && rally.status == 'active'
        && validMapId(rally.mapId)
        && validMapPercent(rally.mapXPercent)
        && validMapPercent(rally.mapYPercent)
        && (rally.scheduledTime == null || rally.scheduledTime is timestamp)
        && rally.expiresAt is timestamp;
    }

    function validResponse(response, rallyPointId, uid) {
      return response.keys().hasOnly(['rallyPointId', 'memberId', 'responseStatus', 'updatedAt'])
        && response.rallyPointId == rallyPointId
        && response.memberId == uid
        && response.responseStatus in ['heading-there', 'arrived', 'cannot-make-it'];
    }

    match /authorizedUsers/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /appConfig/{document=**} {
      allow read: if authorized();
      allow write: if false;
    }

    match /members/{uid} {
      allow read: if authorized();
      allow create: if authorized() && request.auth.uid == uid
        && validMemberLocation(request.resource.data);
      allow update: if authorized() && request.auth.uid == uid && validMemberUpdate();
      allow delete: if authorized() && request.auth.uid == uid;
    }

    match /rallyPoints/{rallyPointId} {
      allow read: if authorized();
      allow create: if authorized() && validRallyPointCreate(request.resource.data);
      allow update: if authorized() && validExpiration();
      allow delete: if false;

      match /responses/{uid} {
        allow read: if authorized();
        allow create: if authorized()
          && request.auth.uid == uid
          && activeRallyPoint(rallyPointId)
          && validResponse(request.resource.data, rallyPointId, uid);
        allow update: if authorized()
          && request.auth.uid == uid
          && activeRallyPoint(rallyPointId)
          && validResponse(request.resource.data, rallyPointId, uid)
          && request.resource.data.rallyPointId == resource.data.rallyPointId
          && request.resource.data.memberId == resource.data.memberId;
        allow delete: if false;
      }
    }

    match /pushSubscriptions/{subscriptionId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
