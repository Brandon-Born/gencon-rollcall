{
  "buildCommand": "npm run build",
  "devCommand": "npm run start:local -- --host 127.0.0.1 --port $PORT",
  "outputDirectory": "dist/gencon-rollcall/browser",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
